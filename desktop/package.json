{
  "name": "hkustgzconnect",
  "version": "0.2.3",
  "description": "HKUST(GZ) campus SSL-VPN — native desktop client (engine: zju-connect)",
  "main": "main.js",
  "author": "heeh02",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cn.edu.hkust-gz.connect",
    "productName": "hkustgzconnect",
    "artifactName": "hkustgzconnect-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "engine",
        "to": "engine",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        { "target": "zip", "arch": ["arm64", "x64"] },
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "hkustgzconnect-${version}"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Network"
    }
  }
}
